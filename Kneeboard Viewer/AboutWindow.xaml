<Window x:Class="Kneeboard_Viewer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="About Kneeboard Viewer"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Kneeboard Viewer" FontSize="20" FontWeight="Bold"/>
        <TextBlock x:Name="VersionText" Margin="0,2,0,0" Foreground="#666" Text="Version"/>

        <TextBlock Margin="0,16,0,0" TextWrapping="Wrap"
                   Text="Watches your DCS World Saved Games\Tracks\Multiplayer folder, extracts the per-aircraft kneeboard pages from the latest mission track, and displays them alongside your static per-aircraft kneeboards."/>
        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                   Text="Pick an aircraft and flip through its kneeboard pages with the toolbar, your keyboard hotkeys, or a controller. Use Fullscreen for an undistracted view, and Reload to pick up the newest track."/>

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Project: " VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/BigWhale/kneeboard-viewer"
                           RequestNavigate="Hyperlink_RequestNavigate">https://github.com/BigWhale/kneeboard-viewer</Hyperlink>
            </TextBlock>
        </StackPanel>

        <Button Content="Close" Click="Close_Click" Padding="14,4"
                HorizontalAlignment="Right" Margin="0,20,0,0" IsDefault="True" IsCancel="True"/>
    </StackPanel>
</Window>
